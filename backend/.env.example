# ── Database ──────────────────────────────────────────────────────────────────
# Nhost PostgreSQL connection string
# Replace [YOUR-PASSWORD] with your actual Nhost database password
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@oncujptgtbayawpovvgv.db.eu-central-1.nhost.run:5432/oncujptgtbayawpovvgv

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# JWT — generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# ── Migrations (optional) ─────────────────────────────────────────────────────
# Defaults to ./internal/database/migrations relative to the binary
# MIGRATIONS_PATH=/app/internal/database/migrations

# Copy to .env.local for local dev, set these as environment variables in production

# Backend API base URL (no trailing slash)
# Local:      http://localhost:8080/api/v1
# Production: https://your-backend.onrender.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# WebSocket URL
# Local:      ws://localhost:8080/ws
# Production: wss://your-backend.onrender.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Production image hostname (just the hostname, no protocol)
# e.g. your-backend.onrender.com
NEXT_PUBLIC_API_HOST=
